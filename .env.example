# ---------------------------------------------------------------------------
# VoiceForge V2 environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# ---------------------------------------------------------------------------

# --- Clerk (authentication) -------------------------------------------------
# Create an application at https://dashboard.clerk.com
# Enable "Email verification link" as the sign-in method.
# Under Restrictions, turn ON "Restricted" sign-up mode (invite-only).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# --- Neon Postgres (database) ------------------------------------------------
# Create a project at https://console.neon.tech (or via Vercel > Storage > Neon)
# Copy the pooled connection string.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- VoiceForge V2 settings ---------------------------------------------------
# Comma-separated emails that get the admin role on first sign-in.
ADMIN_EMAILS=richard.hoyne@hotmail.com
# Generated apps get separate GitHub repos and Vercel projects. Keep this
# distinct from V1 so V2 never collides with existing voiceforge-* apps.
VOICEFORGE_GENERATED_APP_PREFIX=voiceforgev2

# --- OpenAI (planning agents, Stage 1) ----------------------------------------
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx
# Model used for the planning conversation (change any time, no code changes):
OPENAI_PLANNER_MODEL=gpt-5.6-terra

# Model used by the Code/Debug agents:
OPENAI_CODER_MODEL=gpt-5.6-terra
# Voice model for realtime planning conversations (Stage 5):
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini
# Models pinned into AI-enabled GENERATED apps (Stage 7):
OPENAI_GENAPP_MODEL=gpt-5.6-terra
OPENAI_GENAPP_IMAGE_MODEL=gpt-image-2

# --- VoiceForge V2 public URL (Stage 7) ----------------------------------------
# The URL where the hosted VoiceForge V2 is reachable. Generated apps call it
# from locked server routes for AI usage checks, platform data, file uploads,
# downloads, and member sessions.
VOICEFORGE_PUBLIC_URL=https://voiceforge-v2.vercel.app

# Optional but recommended for generated-app member sessions. Keep this stable
# across deploys so generated apps can verify owner/editor/viewer sessions.
# If omitted, VoiceForge falls back to CLERK_SECRET_KEY, then DATABASE_URL.
VOICEFORGE_PLATFORM_SESSION_SECRET=replace-with-a-long-random-secret

# --- Platform files (Stage 11A) ------------------------------------------------
# The initial V2 file provider stores small validated app attachments in Neon
# through the locked platform-files API. No Vercel Blob/S3 token is required yet.
# Current limits: 2 MB per file, 250 files per app, 25 MB per app.

# --- Platform notifications and jobs (Stage 11B) -------------------------------
# In-app notifications and the notification outbox work without an email token.
# To deliver email instead of queueing it in the outbox, create a Resend API key
# and set a verified sender address/domain.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# VOICEFORGE_NOTIFICATION_FROM=VoiceForge <notifications@your-domain.com>

# Optional secret for the locked scheduled-job runner endpoint. Use this as the
# Bearer token for POST /api/platform-jobs/run from Vercel Cron or a manual
# operational trigger.
# VOICEFORGE_CRON_SECRET=replace-with-a-long-random-secret

# --- GitHub (generated app repos, Stage 2) -------------------------------------
# Create a FINE-GRAINED personal access token at
# https://github.com/settings/personal-access-tokens/new with:
#   Repository access: All repositories
#   Permissions -> Repository permissions:
#     Administration: Read and write   (create repos)
#     Contents:       Read and write   (commit code)
# Generated apps get private repos named voiceforgev2-<app-slug>.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
GITHUB_OWNER=your-github-username

# Where generated apps are built/tested locally (optional; default: tmp dir)
# BUILD_WORKSPACE_DIR=/Users/you/voiceforge-v2-builds

# --- Vercel (deployments, Stage 3) ---------------------------------------------
# Create a token at https://vercel.com/account/settings/tokens (scope: full).
# Also make sure Vercel's GitHub integration has access to ALL repositories
# (Vercel dashboard -> Settings -> Git), so new voiceforgev2-* repos deploy.
VERCEL_TOKEN=xxxxxxxxxxxx
# Only needed if your Vercel projects live in a team, not a personal account:
# VERCEL_TEAM_ID=team_xxxxxxxx
